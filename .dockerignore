# Build-context hygiene: keep secrets, the ~7.9GB snapshot cache, dev DBs/caches,
# and node/python cruft out of the image (and out of ECR). Run `git lfs pull`
# before building so backend/data/aicure.db is the real file, not an LFS pointer.
.git
.gitattributes
.venv
**/__pycache__/
**/*.pyc
.pytest_cache
backend/.pytest_cache
backend/.env
backend/aicure.db

# Everything under backend/data is dev/runtime junk (snapshots, logs, WAL
# sidecars, uploads, nlp cache) EXCEPT the seed DB the image must ship.
backend/data/*
!backend/data/aicure.db

frontend/node_modules
frontend/dist
*.log
.DS_Store
