# Generated artifacts. The main aicure.db lives in Git LFS (see .gitattributes)
# so deploys don't have to re-run ingest. The transient journal/WAL/SHM files
# and the snapshot/upload caches stay ignored.
backend/data/snapshots/
backend/data/uploads/
backend/data/clinical_trials.db
backend/data/aicure.db-journal
backend/data/aicure.db-wal
backend/data/aicure.db-shm
backend/data/email_previews/
backend/data/nlp_cache.json
backend/data/logs/

# Node
node_modules/
frontend/dist/
frontend/.vite/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
